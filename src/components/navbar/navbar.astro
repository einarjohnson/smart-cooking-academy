---
import Container from "@components/container.astro";
import Link from "@components/ui/link.astro";
import Dropdown from "./dropdown.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

const menuitems = [
  {
    title: "Home",
    path: "#home",
  },
  {
    title: "Courses",
    path: "#courses",
  },
  {
    title: "Course dates",
    path: "#course-dates",
  },
  {
    title: "Pricing",
    path: "#pricing",
  },
  {
    title: "About",
    path: "#about",
  },
  {
    title: "Testimonials",
    path: "#testimonials",
  },
  {
    title: "Contact",
    path: "#contact",
  },
];
---

<Container>
  <header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md rounded-2xl shadow-lg my-5">
    <Astronav>
      <div class="flex w-full items-center justify-between p-4">
        <a href="#home" class="flex items-center hover:scale-105 transition-transform duration-300">
          <img src="/logo.png" alt="Smart Cooking Academy" class="h-14 md:h-16 w-auto" />
        </a>
        
        <div class="block lg:hidden">
          <MenuIcon class="w-7 h-7 text-orange-500 hover:text-pink-500" />
        </div>
        
        <MenuItems class="hidden lg:flex">
          <ul class="flex flex-row gap-1">
            {
              menuitems.map((item, index) => (
                <>
                  {item.children && (
                    <Dropdown
                      title={item.title}
                      children={item.children}
                      lastItem={index === menuitems.length - 1}
                    />
                  )}

                  {!item.children && (
                    <li>
                      <a
                        href={item.path}
                        class="flex px-4 py-2 items-center text-gray-700 hover:text-orange-500 font-medium transition-all duration-300 hover:scale-110 rounded-lg hover:bg-orange-50">
                        <span>{item.title}</span>
                        {item.badge && (
                          <span class="ml-1 px-2 py-0.5 text-[10px] animate-pulse font-semibold uppercase text-white bg-purple-500 rounded-full">
                            New
                          </span>
                        )}
                      </a>
                    </li>
                  )}
                </>
              ))
            }
          </ul>
        </MenuItems>
      </div>
      
      <MenuItems class="lg:hidden w-full border-t border-gray-200">
        <ul class="flex flex-col p-4">
          {
            menuitems.map((item, index) => (
              <>
                {item.children && (
                  <Dropdown
                    title={item.title}
                    children={item.children}
                    lastItem={index === menuitems.length - 1}
                  />
                )}

                {!item.children && (
                  <li>
                    <a
                      href={item.path}
                      class="flex px-4 py-3 items-center text-gray-700 hover:text-orange-500 font-medium transition-all duration-300 hover:bg-orange-50 rounded-lg">
                      <span>{item.title}</span>
                      {item.badge && (
                        <span class="ml-1 px-2 py-0.5 text-[10px] animate-pulse font-semibold uppercase text-white bg-purple-500 rounded-full">
                          New
                        </span>
                      )}
                    </a>
                  </li>
                )}
              </>
            ))
          }
        </ul>
      </MenuItems>
    </Astronav>
  </header>
</Container>

<script>
  // Smooth scroll behavior
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        target.scrollIntoView({
          behavior: 'smooth',
          block: 'start'
        });
      }
    });
  });
</script>
