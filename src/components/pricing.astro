---
import { Tick } from "@components/ui/icons";
import Link from "@components/ui/link.astro";

const { plan } = Astro.props;
---

<div class="h-full">
  <div
    class="fun-card h-full flex flex-col w-full order-first lg:order-none border-4 border-fun-orange border-opacity-30 py-6 px-6 bg-gradient-to-br from-white to-orange-50 relative overflow-hidden">
    <div class="absolute top-0 right-0 text-6xl opacity-10">
      {plan.name.includes('Preparatory') ? '🎨' : plan.name.includes('Level 1') ? '⭐' : plan.name.includes('Level 2') ? '🌟' : plan.name.includes('Level 3') ? '✨' : '💫'}
    </div>
    <div class="text-center relative z-10">
      <h4 class="text-xl font-bold bg-gradient-to-r from-fun-orange to-fun-pink bg-clip-text text-transparent">{plan.name}</h4>
      <p class="mt-3 text-5xl font-black text-fun-purple md:text-5xl hover:scale-110 transition-transform duration-300">
        {
          plan.price && typeof plan.price === "object"
            ? plan.price.monthly
            : plan.price
        }
      </p>
    </div>
    <ul class="grid mt-6 text-left gap-y-3 flex-grow">
      {
        plan.features.map((item) => (
          <li class="flex items-start gap-3 text-gray-700">
            <div class="text-fun-green">
              <Tick class="w-6 h-6" />
            </div>
            <span class="text-sm">{item}</span>
          </li>
        ))
      }
    </ul>
    <div class="flex mt-6">
      <Link
        href={plan.button.link || "#"}
        block
        style={plan.popular ? "primary" : "outline"}>
        {plan.button.text || "Get Started"} 🚀
      </Link>
    </div>
  </div>
</div>
